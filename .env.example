NODE_ENV=development
ALLOW_DEV_HEADER_AUTH=true
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6432/suivo
DOCKER_DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:6432/suivo
SHARED_DEV_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6432/suivo
REDIS_URL=redis://localhost:6379
# Clerk: replace with your Clerk Frontend API domain
JWT_ISSUER=https://<your-clerk-domain>
JWT_AUDIENCE=suivo-api
JWT_JWKS_URI=https://<your-clerk-domain>/.well-known/jwks.json
WEBHOOK_SHARED_SECRET=
INTERNAL_API_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
KMS_PROVIDER=local
# Generate once and keep stable: openssl rand -base64 32
LOCAL_ENCRYPTION_KEY_BASE64=
GCP_PROJECT_ID=suivoapp
CLOUD_SQL_INSTANCE_CONNECTION_NAME=<project>:<region>:<instance>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_CALLER_NUMBER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/v1/mailboxes/oauth/gmail/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/v1/mailboxes/oauth/outlook/callback
MICROSOFT_TENANT_ID=common
OAUTH_STATE_SECRET=
APP_REDIRECT_ALLOWLIST=
MAIL_SYNC_EVERY_MINUTES=5
MAIL_SYNC_NEWER_THAN_HOURS=2
MAIL_SYNC_MAX_RESULTS_PER_BOX=25
MAIL_SYNC_MAILBOX_LIMIT=50
API_BASE_URL=http://localhost:3001
