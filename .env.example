NODE_ENV=development
ALLOW_DEV_HEADER_AUTH=true
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6432/suivo
DOCKER_DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:6432/suivo
SHARED_DEV_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:6432/suivo
REDIS_URL=redis://localhost:6379
# Clerk: replace with your Clerk Frontend API domain
JWT_ISSUER=https://<your-clerk-domain>
JWT_AUDIENCE=suivo-api
JWT_JWKS_URI=https://<your-clerk-domain>/.well-known/jwks.json
WEBHOOK_SHARED_SECRET=
INTERNAL_API_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REALTIME_SIP_URI=
TELNYX_API_KEY=
TELNYX_API_BASE_URL=https://api.telnyx.com/v2
TELNYX_WEBHOOK_PUBLIC_KEY=
TELNYX_CONNECTION_ID=
TELNYX_DEFAULT_ASSISTANT_MODEL=gpt-4o-mini
TELNYX_DEFAULT_ASSISTANT_VOICE=AWS.Polly.Joanna-Neural
VOICE_ASSISTANT_PROVIDER_DEFAULT=openai_sip
KMS_PROVIDER=local
# Generate once and keep stable: openssl rand -base64 32
LOCAL_ENCRYPTION_KEY_BASE64=
GCP_PROJECT_ID=suivoapp
CLOUD_SQL_INSTANCE_CONNECTION_NAME=<project>:<region>:<instance>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.suivo.ca/v1/mailboxes/oauth/gmail/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://api.suivo.ca/v1/mailboxes/oauth/outlook/callback
MICROSOFT_TENANT_ID=common
OAUTH_STATE_SECRET=
APP_REDIRECT_ALLOWLIST=
MAIL_SYNC_EVERY_MINUTES=5
MAIL_SYNC_NEWER_THAN_HOURS=2
MAIL_SYNC_MAX_RESULTS_PER_BOX=25
MAIL_SYNC_MAILBOX_LIMIT=50
EMAIL_INTAKE_ENABLED=true
EMAIL_INTAKE_SHADOW_MODE=true
EMAIL_INTAKE_CUTOVER_ENABLED=false
EMAIL_INTAKE_CREATE_THRESHOLD=70
EMAIL_INTAKE_REVIEW_THRESHOLD=40
EMAIL_INTAKE_REVIEW_SLA_MINUTES=60
EMAIL_INTAKE_BLOCKED_LOCALPARTS=noreply,no-reply,donotreply,do-not-reply,mailer-daemon,system
EMAIL_INTAKE_BLOCKED_DOMAINS=
EMAIL_INTAKE_DISPOSABLE_DOMAINS=mailinator.com,guerrillamail.com,10minutemail.com,yopmail.com,tempmail.com
MAIL_BACKFILL_NEWER_THAN_HOURS=8760
MAIL_BACKFILL_MAX_RESULTS=5000
MAIL_BACKFILL_PREVIEW_LIMIT=10
MAIL_BACKFILL_AWAIT_CLASSIFICATION=false
API_BASE_URL=https://api.suivo.ca
