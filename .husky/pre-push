#!/usr/bin/env sh
set -e

if [ "${SKIP_PUSH_CHECKS:-0}" = "1" ]; then
  echo "Skipping pre-push checks (SKIP_PUSH_CHECKS=1)."
  exit 0
fi

if [ "${SKIP_DB_DOCTOR:-0}" = "1" ]; then
  echo "Skipping DB doctor check (SKIP_DB_DOCTOR=1)."
  pnpm gcp:check
  pnpm env:check
  pnpm checks:fast
  exit 0
fi

pnpm checks:all
